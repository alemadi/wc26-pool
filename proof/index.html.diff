+  if(res.err==="wrong_pin"){lsDel("wc:pin");needPin();return false;}
+  return false;
+}
+/* The server's answer is canonical: any pick it kept sealed snaps back here */
+function reconcilePicks(srv){
+  if(!srv||!state.player)return;
+  const sp=srv.predictions||{},lp=state.player.predictions||(state.player.predictions={});
+  let sealed=0;
+  const ids={};Object.keys(lp).forEach(k=>ids[k]=1);Object.keys(sp).forEach(k=>ids[k]=1);
+  for(const id in ids){
+    const f=FXID[id];if(!f||!lockedM(f))continue;
+    if(JSON.stringify(lp[id]||null)!==JSON.stringify(sp[id]||null)){
+      if(sp[id])lp[id]=sp[id];else delete lp[id];
+      syncPickRow(id);sealed++;
+    }
+  }
+  if(locked(CHAMP_LOCK)&&srv.champ!==state.player.champ)state.player.champ=srv.champ;
+  if(sealed){syncProgress();updateChip();toast("🔒 "+sealed+" pick"+(sealed>1?"s":"")+" had already kicked off — kept as sealed");}
+}
+function needPin(){
+  toast("Enter your 4-digit PIN to keep your picks saving");
