+/* ===== RPC bridge: ALL shared writes go through server-side functions =====
+   kv is read-only to the browser since sql/protect.sql. Kickoff locks and
+   PINs are enforced by Postgres on the database clock — console tricks and
+   direct REST calls bounce off the wall, for everyone equally. */
+async function rpc(fn,args){
+  try{const r=await fetch(SUPABASE_URL+"/rest/v1/rpc/"+fn,{method:"POST",headers:SBH,body:JSON.stringify(args||{})});
+    let j=null;try{j=await r.json();}catch(e){}
+    return {ok:r.ok,j:j,err:(!r.ok&&j&&(j.message||j.hint))||null};
+  }catch(e){return {ok:false,j:null,err:"network"};}
+}
